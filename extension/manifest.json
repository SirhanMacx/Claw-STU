{
  "manifest_version": 3,
  "name": "Claw-STU — Ask Stuart",
  "version": "1.1.0",
  "description": "Highlight text on any page and ask Stuart about it.",
  "permissions": ["contextMenus", "activeTab", "storage"],
  "host_permissions": ["http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ask Stuart"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
